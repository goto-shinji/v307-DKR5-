connect '/C=3 /BAUD=115200'

	PRGNAME='P00.FLD'
	call ymdmSend

	PRGNAME='P00.DAT'
	call ymdmSend

	PRGNAME='P11.FLD'
	call ymdmSend

	PRGNAME='P11.DAT'
	call ymdmSend

	;messagebox '몭륪뢎뿹' '뢎뿹'
closett
end

:ymdmSend
	getdir filePath
	strconcat filePath '\'
	strconcat filePath PRGNAME
	ymodemsend filePath
	if result=1 then
	else
		msg=''
		strconcat msg PRGNAME
		strconcat msg ' 궻몭륪궸렪봲'
		messagebox msg '몭륪렪봲'
		closett
		end
	endif
return
