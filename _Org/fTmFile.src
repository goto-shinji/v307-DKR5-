	'=================================================================
	'データ
	'=================================================================
	Const	Tmf.Fnm$ = "timefile.txt"
	Const	Tmf.Fno% = 2
	Const	Tmf.Max% = 32000

	Global	Tmf.Rec$[255]
	Global	Tmf.Count
	'----------------------------------------------------------------
	' オープン
	'----------------------------------------------------------------
	sub Tmf.Open
		open Tmf.Fnm$ as Tmf.Fno% record Tmf.Max%
		field Tmf.Fno% , 255 as Tmf.Rec$
		Tmf.Count = lof(Tmf.Fno%)
	end sub

	'----------------------------------------------------------------
	' クローズ
	'----------------------------------------------------------------
	sub Tmf.Close
		Tmf.Count = lof(Tmf.Fno%)
		Close( Tmf.Fno% )
	end sub

	'----------------------------------------------------------------
	' 初期化
	'----------------------------------------------------------------
	sub Tmf.Init
		Tmf.Open
		Tmf.Close
	end sub
	Tmf.Init

	'----------------------------------------------------------------
	' 読み込み時間をセットする
	'----------------------------------------------------------------
	Sub Tmf.SetTime
		Tmf.Open
		if( Tmf.Count>0 )then
			get Tmf.Fno%,1
			date$ = mid$(Tmf.Rec$, 3,8)
			time$ = mid$(Tmf.Rec$,12,8)
		endif
		Tmf.Close
	End Sub
