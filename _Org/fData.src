	'=================================================================
	'データ
	'=================================================================
	Const	Dat.Fnm$ = "tksdata.csv"
	Const	Dat.Fno% = 2
	Const	Dat.Max% = 32000

	Global	Dat.Rec$[255]
	Global	Dat.Count
	'----------------------------------------------------------------
	' オープン
	'----------------------------------------------------------------
	sub Dat.Open
		open Dat.Fnm$ as Dat.Fno% record Dat.Max%
		field Dat.Fno% , 255 as Dat.Rec$
		Dat.Count = lof(Dat.Fno%)
	end sub

	'----------------------------------------------------------------
	' クローズ
	'----------------------------------------------------------------
	sub Dat.Close
		Dat.Count = lof(Dat.Fno%)
		Close( Dat.Fno% )
	end sub

	'----------------------------------------------------------------
	' 初期化
	'----------------------------------------------------------------
	sub Dat.Init
		Dat.Open
		Dat.Close
	end sub
	Dat.Init

	'----------------------------------------------------------------
	' 実績データを全件削除する
	'----------------------------------------------------------------
	sub Dat.Clear
		Dat.Open
		CLFILE Dat.Fno%
		Dat.Close
	end sub

	'----------------------------------------------------------------
	' 書込み
	'----------------------------------------------------------------
	Sub Dat.Put
		Dat.Open
		put Dat.Fno%
		Dat.Close
	End Sub
